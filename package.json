{
  "name": "vladikdb",
  "version": "4.0.0",
  "description": "Simple and fast JSON database for node and browser",
  "keywords": [
    "database",
    "db",
    "electron",
    "embed",
    "embedded",
    "flat",
    "json",
    "local",
    "localStorage",
    "sessionStorage",
    "browser",
    "lowdb",
    "stream",
    "streaming"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vladpuz/vladikdb.git"
  },
  "license": "MIT",
  "author": "Vladislav Puzyrev",
  "type": "module",
  "exports": {
    ".": "./dist/index.js",
    "./node": "./dist/node.js",
    "./browser": "./dist/browser.js"
  },
  "typesVersions": {
    "*": {
      ".": [
        "dist/index.d.ts"
      ],
      "node": [
        "dist/node.d.ts"
      ],
      "browser": [
        "dist/browser.d.ts"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rimraf dist && tsc --project tsconfig.build.json",
    "check": "npm run typecheck && npm run lint && npm run format",
    "format": "prettier --check .",
    "lint": "eslint .",
    "prepack": "npm run build && npm run check && npm run test",
    "prepare": "husky",
    "test": "node --test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "steno": "^4.0.2"
  },
  "devDependencies": {
    "@tsconfig/node-lts": "^24.0.0",
    "@tsconfig/node-ts": "^23.6.4",
    "@tsconfig/strictest": "^2.0.8",
    "@types/node": "^25.6.0",
    "eslint": "^10.2.1",
    "eslint-config-vladpuz": "^4.0.1",
    "husky": "^9.1.7",
    "prettier": "^3.8.3",
    "prettier-config-vladpuz": "^3.0.0",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3"
  }
}
